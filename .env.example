# Optional public API base URL for native/mobile clients.
# On Vercel web, same-origin /api is used automatically.
EXPO_PUBLIC_DIRECTORY_API_URL=https://your-vercel-app.vercel.app

# Server-side Vercel API variables.
CENTRAL_SUPABASE_URL=https://your-central-project.supabase.co
CENTRAL_SUPABASE_ANON_KEY=your-central-anon-key
CENTRAL_SUPABASE_SERVICE_ROLE_KEY=your-central-service-role-key
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Optional single-school defaults. Leave blank for normal multi-school onboarding.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_SCHOOL_ID=default-school
